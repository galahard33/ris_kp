@model GaussWebApp.Models.GaussViewModel

<!-- @{
    ViewData["Title"] = "Решение СЛАУ — Метод Гаусса";
} -->

@section Styles {
    <style>
        .preview-box {
            background: #f9f9f9;
            border-left: 4px solid #0d6efd;
            padding: 12px;
            border-radius: 6px;
            font-family: Consolas, monospace;
            font-size: 0.85rem;
            max-height: 300px;
            overflow: auto;
        }
        .btn-download {
            transition: all 0.2s;
        }
        .btn-download:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.15);
        }
        .result-card {
            animation: fadeIn 0.5s ease-out;
        }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="text-center mb-5">
                <h1 class="display-5 fw-bold">🔢 Решение СЛАУ — Метод Гаусса</h1>
                <p class="lead text-muted">
                    Генерация, загрузка и параллельное решение систем линейных уравнений
                </p>
            </div>

            <form method="post" enctype="multipart/form-data" id="gaussForm">
                <div class="row g-4">
                    <!-- Размер матрицы -->
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="number" class="form-control" id="MatrixSize" name="MatrixSize"
                                   value="@Model.MatrixSize" min="100" max="5000" required />
                            <label for="MatrixSize">Размер матрицы (N)</label>
                        </div>
                        <div class="form-text text-muted">
                            <i class="bi bi-info-circle"></i>
                            От 100 до 5000. Файлы >3000 могут требовать много памяти.
                        </div>
                    </div>

                    <!-- Число потоков -->
                    <div class="col-md-6">
                        <div class="form-floating">
                            <select class="form-select" id="ThreadCount" name="ThreadCount">
                                <option value="1">1 поток (однопоточно)</option>
                                <option value="2" selected>2 потока</option>
                                <option value="4">4 потока</option>
                                <option value="8">8 потоков</option>
                            </select>
                            <label for="ThreadCount">Число потоков</label>
                        </div>
                    </div>

                    <!-- Загрузка файла -->
                    <div class="col-12">
                        <label class="form-label">Загрузить свою матрицу (опционально)</label>
                        <div class="input-group">
                            <input type="file" class="form-control" name="UploadedFile" accept=".txt"
                                   id="fileInput" onchange="updateFileLabel()" />
                            <span class="input-group-text" id="fileLabel">Выберите файл...</span>
                        </div>
                        <div class="form-text text-muted">
                            <i class="bi bi-file-text"></i>
                            Формат: первая строка — N, затем N строк вида: <code>a11 a12 ... | b1</code>
                        </div>
                    </div>

                    <!-- Кнопки -->
                    <div class="col-12 d-flex gap-3 flex-wrap">
                        <button type="submit" class="btn btn-primary btn-lg flex-grow-1" id="solveBtn">
                            <i class="bi bi-play-circle"></i> Решить
                        </button>
                        <button type="submit" name="RequestDownload" value="true"
                                class="btn btn-outline-secondary btn-lg flex-grow-1" id="downloadBtn">
                            <i class="bi bi-download"></i> Скачать матрицу (@Model.MatrixSize×@Model.MatrixSize)
                        </button>
                    </div>
                </div>
            </form>

            <!-- Прогресс -->
            <div id="loading" class="mt-4 d-none">
                <div class="d-flex align-items-center">
                    <div class="spinner-border text-primary me-3" role="status">
                        <span class="visually-hidden">Загрузка...</span>
                    </div>
                    <strong>Выполняется расчёт... Это может занять от нескольких секунд до нескольких минут.</strong>
                </div>
            </div>

            <!-- Ошибки -->
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show mt-4" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрыть"></button>
                </div>
            }

            @if (Model.HasResult)
{
    <div class="result-card mt-5">
        <div class="card border-0 shadow">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-graph-up"></i> Результаты расчёта</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item"><strong>Размер:</strong> @Model.MatrixSize×@Model.MatrixSize</li>
                            <li class="list-group-item"><strong>Однопоточно:</strong> @($"{Model.TimeSequential:F3} с")</li>
                            <li class="list-group-item"><strong>@Model.ThreadCount поток(а/ов):</strong> @($"{Model.TimeParallel:F3} с")</li>
                            <li class="list-group-item">
                                <strong>Ускорение:</strong> 
                                <span class="text-success fw-bold">@($"{Model.Speedup:F2}×")</span>
                            </li>
                            <li class="list-group-item"><strong>Макс. ошибка:</strong> @($"{Model.MaxError:E3}")</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <div class="alert alert-info">
                            <i class="bi bi-lightbulb"></i> Ускорение &lt;1.0 говорит о накладных расходах.
                            Идеальное ускорение редко достижимо из-за последовательных частей алгоритма.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-md-6">
                <h6><i class="bi bi-grid-3x3"></i> Исходная матрица (фрагмент)</h6>
                <div class="preview-box mt-2">
                    @foreach (var line in Model.MatrixPreview ?? Array.Empty<string>())
                    {
                        <div>@line</div>
                    }
                </div>
            </div>
            <div class="col-md-6">
                <h6><i class="bi bi-calculator"></i> Решение (первые 10 элементов)</h6>
                <div class="preview-box mt-2">
                    @foreach (var line in Model.SolutionPreview ?? Array.Empty<string>())
                    {
                        <div>@line</div>
                    }
                </div>
            </div>
        </div>
    </div>
}
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.min.js"></script>
    <script>
        // Обновление текста кнопки скачивания при изменении размера
        document.getElementById('MatrixSize').addEventListener('input', function () {
            const n = this.value || 1000;
            document.getElementById('downloadBtn').innerHTML = 
                `<i class="bi bi-download"></i> Скачать матрицу (${n}×${n})`;
        });

        // Обновление метки файла
        function updateFileLabel() {
            const fileInput = document.getElementById('fileInput');
            const fileLabel = document.getElementById('fileLabel');
            if (fileInput.files.length > 0) {
                fileLabel.textContent = fileInput.files[0].name;
            } else {
                fileLabel.textContent = 'Выберите файл...';
            }
        }

        // Блокировка формы и показ прогресса
        document.getElementById('gaussForm').addEventListener('submit', function () {
            const solveBtn = document.getElementById('solveBtn');
            const downloadBtn = document.getElementById('downloadBtn');
            const loading = document.getElementById('loading');

            // Если нажата кнопка "Скачать" — не блокируем
            const submitBtn = event.submitter;
            if (submitBtn && submitBtn.name === 'RequestDownload') {
                solveBtn.disabled = false;
                return;
            }

            // Иначе — блокируем и показываем прогресс
            solveBtn.disabled = true;
            solveBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Выполняется...';
            downloadBtn.disabled = true;
            loading.classList.remove('d-none');
        });
    </script>
}